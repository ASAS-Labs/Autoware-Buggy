<launch>
  <arg name="launch_driver" default="true"/>
  <arg name="vehicle_mirror_param_file"/>
  <arg name="use_concat_filter" default="true"/>
  <arg name="pointcloud_container_name" default="pointcloud_container"/>
  <arg name="vehicle_id" default="$(env VEHICLE_ID default)"/>

  <group>
    <push-ros-namespace namespace="lidar"/>
    <group>
      <push-ros-namespace namespace="top"/>

      <!-- Relay: /ouster/points → /sensing/lidar/top/pointcloud_raw -->
      <!-- Ouster driver runs separately via ouster_relay.py          -->
      <node pkg="topic_tools" exec="relay" name="lidar_relay"
            if="$(var launch_driver)">
        <param name="input_topic"  value="/ouster/points"/>
        <param name="output_topic" value="/sensing/lidar/top/pointcloud_raw"/>
      </node>

    </group>

    <!-- Pointcloud preprocessing pipeline (crop box, ring filter, concat) -->
    <include file="$(find-pkg-share gokart_sensor_kit_launch)/launch/pointcloud_preprocessor.launch.py">
      <arg name="base_frame"                value="base_link"/>
      <arg name="use_intra_process"         value="true"/>
      <arg name="use_multithread"           value="true"/>
      <arg name="use_concat_filter"         value="$(var use_concat_filter)"/>
      <arg name="pointcloud_container_name" value="$(var pointcloud_container_name)"/>
    </include>

  </group>
</launch>
